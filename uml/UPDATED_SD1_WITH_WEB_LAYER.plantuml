@startuml Web_Layer_Integration_Sequence

title Web Layer - Guest Online Reservation Flow (Updated SD-01 with Web Layer)

actor "Guest" as G
participant "Browser" as BROWSER
participant "AuthFilter" as FILTER
participant "LoginServlet" as LOGIN_SERVLET
participant "SystemController" as SYS_CTRL
participant "UserService" as USER_SVC
participant "UserRepository" as USER_REPO
participant "Session" as SESSION
participant "ReservationServlet" as RES_SERVLET
participant "ReservationController" as RES_CTRL
participant "BookingService" as BOOKING_SVC
participant "OnlineResService" as ONLINE_RES
participant "PaymentService" as PAY_SVC
participant "OnlineGatewayAdapter" as GATEWAY
participant "SecureBankPortal" as BANK

== PHASE 1: AUTHENTICATION ==

G -> BROWSER: Opens app at http://localhost:8080/projectweb
activate BROWSER

BROWSER -> FILTER: GET / (no session)
activate FILTER

FILTER -> FILTER: Check session - NO SESSION FOUND
FILTER -> BROWSER: Redirect to /login
deactivate FILTER

BROWSER -> LOGIN_SERVLET: GET /login
activate LOGIN_SERVLET

LOGIN_SERVLET -> BROWSER: Render login.jsp
deactivate LOGIN_SERVLET

G -> BROWSER: Enter username & password
activate BROWSER

BROWSER -> FILTER: POST /login
activate FILTER

FILTER -> LOGIN_SERVLET: Forward to servlet
deactivate FILTER

LOGIN_SERVLET -> SYS_CTRL: login("guest_user", "password")
activate SYS_CTRL

SYS_CTRL -> USER_SVC: authenticate()
activate USER_SVC

USER_SVC -> USER_REPO: findByUsername("guest_user")
activate USER_REPO

USER_REPO -> USER_REPO: Query database
note right of USER_REPO
  Using UserDAOImpl
  with DatabaseConnection
  Singleton
end note

USER_REPO --> USER_SVC: User found
deactivate USER_REPO

USER_SVC -> USER_SVC: validatePassword()
USER_SVC --> SYS_CTRL: AuthResult (success)
deactivate USER_SVC

SYS_CTRL --> LOGIN_SERVLET: return success
deactivate SYS_CTRL

LOGIN_SERVLET -> SESSION: Create HttpSession
note right of SESSION
  Store: userId, username, role
  Timeout: 30 minutes
  Cookie: HttpOnly
end note

LOGIN_SERVLET -> BROWSER: Redirect to /reservation/dashboard
deactivate LOGIN_SERVLET

== PHASE 2: ROOM SEARCH ==

BROWSER -> FILTER: GET /reservation/dashboard
activate FILTER

FILTER -> SESSION: Validate session
FILTER -> FILTER: Check role == GUEST
FILTER -> BROWSER: Allow access
deactivate FILTER

BROWSER -> RES_SERVLET: GET /reservation/search
activate RES_SERVLET

RES_SERVLET -> BROWSER: Render roomSearch.jsp
deactivate RES_SERVLET

G -> BROWSER: Enter check-in & check-out dates
activate BROWSER

BROWSER -> RES_SERVLET: POST /reservation/search
activate RES_SERVLET

RES_SERVLET -> RES_CTRL: searchRooms(2026-02-25, 2026-02-27)
activate RES_CTRL

RES_CTRL -> BOOKING_SVC: getAvailableRooms()
activate BOOKING_SVC

BOOKING_SVC -> BOOKING_SVC: Call RoomService.getAvailable()
BOOKING_SVC -> BROWSER: Return List<RoomDTO>
deactivate BOOKING_SVC

RES_CTRL --> BROWSER: searchResults.jsp with rooms
deactivate RES_CTRL

RES_SERVLET -> BROWSER: Render searchResults.jsp
deactivate RES_SERVLET

== PHASE 3: RESERVATION CREATION ==

G -> BROWSER: Select room & enter guest details
activate BROWSER

BROWSER -> RES_SERVLET: POST /reservation/create
activate RES_SERVLET

RES_SERVLET -> RES_CTRL: makeReservation(guestDTO, roomId, dates)
activate RES_CTRL

RES_CTRL -> BOOKING_SVC: makeOnlineReservation()
activate BOOKING_SVC

BOOKING_SVC -> ONLINE_RES: processBooking() [Factory Method]
activate ONLINE_RES

ONLINE_RES -> ONLINE_RES: createReservation() [Factory creates OnlineReservation]
note right of ONLINE_RES
  Factory Method Pattern
  Creates OnlineReservation
  with emailSent = false
end note

ONLINE_RES -> ONLINE_RES: confirm()
BOOKING_SVC --> BOOKING_SVC: Reservation created
deactivate ONLINE_RES

== PHASE 4: PAYMENT ==

BOOKING_SVC -> PAY_SVC: processPayment(totalAmount)
activate PAY_SVC

PAY_SVC -> GATEWAY: pay(amount)
activate GATEWAY

GATEWAY -> BANK: generatePaymentLink()
activate BANK

BANK --> GATEWAY: paymentLink
deactivate BANK

note right of GATEWAY
  Adapter Pattern
  Abstracts payment channel
  User redirected to bank portal
end note

GATEWAY --> PAY_SVC: success
deactivate GATEWAY

PAY_SVC --> BOOKING_SVC: payment confirmed
deactivate PAY_SVC

== PHASE 5: CONFIRMATION & EMAIL ==

BOOKING_SVC -> ONLINE_RES: sendConfirmationEmail()
activate ONLINE_RES

ONLINE_RES -> ONLINE_RES: Send email to guest
note right of ONLINE_RES
  Email service integration
  Sends confirmation with:
  - Reservation ID
  - Room details
  - Payment confirmation
end note

ONLINE_RES -> ONLINE_RES: markEmailSent()
BOOKING_SVC -> BROWSER: ReservationDTO
deactivate ONLINE_RES

RES_CTRL --> BROWSER: reservationConfirmation.jsp
deactivate RES_CTRL

RES_SERVLET -> BROWSER: Render confirmation page
deactivate RES_SERVLET

BROWSER -> G: Display confirmation & reservation ID
deactivate BROWSER

== NOTES ==

note over G, BANK
  **Web Layer Integration Points:**

  1. **AuthFilter** - Intercepts all requests
     Validates session and role-based access

  2. **Servlets** - Route HTTP requests
     Delegate to controllers (thin layer)

  3. **Controllers** - Already existed
     Now receive requests from servlets

  4. **Services** - Already existed
     Called by controllers as before

  5. **Session** - Maintains user state
     HttpSession stores role for authorization

  **Design Patterns Applied:**
  - Factory Method: OnlineReservation creation
  - Strategy: Pricing calculation (not shown)
  - Adapter: Payment gateway abstraction
  - Facade: BookingService orchestration
  - Singleton: DatabaseConnection
  - DTO Mapper: Conversion layer
end note

@enduml

