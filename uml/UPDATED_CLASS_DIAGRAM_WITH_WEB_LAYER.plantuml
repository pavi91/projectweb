@startuml Updated_System_Architecture_with_Web_Layer

!define BGCOLOR_WEB #E8F4F8
!define BGCOLOR_CONTROLLER #FFF4E6
!define BGCOLOR_SERVICE #F0F8E8
!define BGCOLOR_MAPPER #F8F0FF
!define BGCOLOR_DAO #FFE8E8
!define BGCOLOR_DB #E0E0E0

' ============================================================
' WEB/PRESENTATION LAYER (NEW)
' ============================================================

package "Web Layer (Presentation)" <<BGCOLOR_WEB>> {
    package "JSP Views" {
        interface "IView" {
            + render()
        }

        class "login.jsp" implements IView
        class "error.jsp" implements IView
        class "404.jsp" implements IView
        class "500.jsp" implements IView
        class "index.jsp" implements IView

        package "Guest Views" {
            class "roomSearch.jsp" implements IView
            class "searchResults.jsp" implements IView
            class "reservation.jsp" implements IView
            class "reservationConfirmation.jsp" implements IView
            class "myReservations.jsp" implements IView
            class "cancelReservation.jsp" implements IView
            class "cancelConfirmation.jsp" implements IView
        }

        package "Receptionist Views" {
            class "receptionistDashboard.jsp" implements IView
            class "walkInForm.jsp" implements IView
            class "walkInConfirmation.jsp" implements IView
            class "checkIn.jsp" implements IView
            class "checkInConfirmation.jsp" implements IView
            class "checkOut.jsp" implements IView
            class "bill.jsp" implements IView
        }

        package "Admin Views" {
            class "adminDashboard.jsp" implements IView
            class "staffManagement.jsp" implements IView
            class "staffCreationConfirmation.jsp" implements IView
            class "reports.jsp" implements IView
            class "revenueReport.jsp" implements IView
            class "occupancyReport.jsp" implements IView
            class "comprehensiveReport.jsp" implements IView
            class "cancellationReport.jsp" implements IView
            class "paymentConfig.jsp" implements IView
            class "paymentConfigConfirmation.jsp" implements IView
            class "maintenance.jsp" implements IView
            class "maintenanceConfirmation.jsp" implements IView
        }
    }

    package "Servlets (HTTP Handlers)" {
        interface "IServlet" {
            + doGet()
            + doPost()
        }

        class "LoginServlet" implements IServlet {
            - userService: UserService
            + doGet(): void
            + doPost(): void
            - handleLogin(): AuthResult
            - createUserSession(): void
        }

        class "ReservationServlet" implements IServlet {
            - bookingService: BookingService
            - roomService: RoomService
            + doGet(): void
            + doPost(): void
            - handleSearch(): List<RoomDTO>
            - handleReservation(): ReservationDTO
            - handleCancellation(): boolean
        }

        class "FrontDeskServlet" implements IServlet {
            - bookingService: BookingService
            + doGet(): void
            + doPost(): void
            - handleWalkIn(): ReservationDTO
            - handleCheckIn(): void
            - handleCheckOut(): ReservationDTO
        }

        class "AdminServlet" implements IServlet {
            - adminController: AdminController
            - reportService: ReportService
            + doGet(): void
            + doPost(): void
            - handleStaffCreation(): void
            - handleReportGeneration(): String
            - handlePaymentConfig(): void
            - handleMaintenance(): void
        }
    }

    package "Filters (Request Interceptors)" {
        interface "IFilter" {
            + doFilter(): void
        }

        class "AuthFilter" implements IFilter {
            - userService: UserService
            + doFilter(): void
            - validateSession(): boolean
            - checkRoleAccess(): boolean
            - redirectToLogin(): void
            - isProtectedUrl(): boolean
        }
    }

    package "Session Management" {
        class "SessionManager" {
            + createSession(): HttpSession
            + validateSession(): boolean
            + getUserFromSession(): UserDTO
            + invalidateSession(): void
            + setSessionTimeout(): void
        }
    }
}

' ============================================================
' CONTROLLER LAYER
' ============================================================

package "Controller Layer" <<BGCOLOR_CONTROLLER>> {
    class "SystemController" {
        -userService: UserService
        +login(u: String, p: String): AuthResult
        +logout(): boolean
        +validateSession(): UserDTO
    }

    class "ReservationController" {
        -bookingService: BookingService
        +searchRooms(): List<RoomDTO>
        +makeReservation(): ReservationDTO
        +cancelReservation(): boolean
    }

    class "FrontDeskController" {
        -bookingService: BookingService
        +checkIn(): void
        +checkOut(): ReservationDTO
    }

    class "AdminController" {
        -userService: UserService
        -reportService: ReportService
        -paymentService: PaymentService
        +createStaffAccount(): void
        +generateReports(): String
        +configurePaymentAdapter(): void
    }
}

' ============================================================
' SERVICE LAYER (Facade Pattern)
' ============================================================

package "Service Layer" <<BGCOLOR_SERVICE>> {
    class "BookingService <<Facade>>" {
        -onlineResService: OnlineResService
        -walkInResService: WalkInResService
        -roomService: RoomService
        -paymentService: PaymentService
        +makeOnlineReservation(): ReservationDTO
        +makeWalkInReservation(): ReservationDTO
        +checkIn(): void
        +checkOut(): ReservationDTO
        +cancelReservation(): boolean
    }

    class "UserService" {
        -userRepository: UserRepository
        +authenticate(): UserDTO
        +createUser(): void
        +getUserById(): UserDTO
    }

    class "RoomService" {
        -roomRepository: RoomRepository
        +getAvailable(): List<RoomDTO>
        +updateStatus(): void
        +getRoomById(): RoomDTO
    }

    class "PaymentService" {
        -currentAdapter: IPaymentAdapter
        +processPayment(): boolean
        +setPaymentAdapter(): void
        +processRefund(): boolean
    }

    class "ReportService" {
        -reservationRepository: ReservationRepository
        +getRevenueStats(): String
        +getOccupancyStats(): String
        +getCancellationStats(): String
    }
}

' ============================================================
' RESERVATION SERVICE (Factory Pattern)
' ============================================================

package "Reservation Service (Factory)" <<BGCOLOR_SERVICE>> {
    class "ReservationService (abstract)" {
        -reservationRepository: ReservationRepository
        -pricingStrategy: IPricingStrategy
        + {abstract} createReservation(): Reservation
        + processBooking(): Reservation
        + setPricingStrategy(): void
        + {abstract} getReservationType(): String
    }

    class "OnlineResService" extends ReservationService {
        + createReservation(): OnlineReservation
        + sendConfirmationEmail(): void
        + sendPaymentReceipt(): void
        + getReservationType(): String
    }

    class "WalkInResService" extends ReservationService {
        + createReservation(): WalkInReservation
        + printReceipt(): void
        + printBill(): void
        + getReservationType(): String
    }
}

' ============================================================
' MAPPER LAYER
' ============================================================

package "Mapper Layer (DTO <-> Entity)" <<BGCOLOR_MAPPER>> {
    class "UserMapper" {
        + {static} toEntity(): User
        + {static} toDTO(): UserDTO
        + {static} updateEntity(): void
    }

    class "GuestMapper" {
        + {static} toEntity(): Guest
        + {static} toDTO(): GuestDTO
        + {static} updateEntity(): void
    }

    class "RoomMapper" {
        + {static} toEntity(): Room
        + {static} toDTO(): RoomDTO
        + {static} updateEntity(): void
    }
}

' ============================================================
' DTO LAYER
' ============================================================

package "DTO Layer (Data Transfer Objects)" {
    class "UserDTO" {
        +id: int
        +username: String
        +role: String
    }

    class "GuestDTO" {
        +id: int
        +name: String
        +nic: String
        +phone: String
    }

    class "RoomDTO" {
        +id: int
        +number: String
        +type: String
        +price: double
    }

    class "ReservationDTO" {
        +id: String
        +status: String
        +totalAmount: double
        +guest: GuestDTO
        +room: RoomDTO
    }
}

' ============================================================
' REPOSITORY/DAO LAYER
' ============================================================

package "Repository/DAO Layer" <<BGCOLOR_DAO>> {
    interface "UserRepository" {
        + findByUsername(): User
        + findById(): User
        + save(): User
        + update(): void
    }

    interface "RoomRepository" {
        + findById(): Room
        + findAvailable(): List<Room>
        + update(): void
    }

    interface "ReservationRepository" {
        + findById(): Reservation
        + findByGuest(): List<Reservation>
        + save(): Reservation
        + update(): void
    }

    class "UserDAOImpl" implements UserRepository {
        - databaseConnection: DatabaseConnection
        + findByUsername(): User
        + findById(): User
        + save(): User
        + update(): void
    }

    class "RoomDAOImpl" implements RoomRepository {
        - databaseConnection: DatabaseConnection
        + findById(): Room
        + findAvailable(): List<Room>
        + update(): void
    }

    class "ReservationDAOImpl" implements ReservationRepository {
        - databaseConnection: DatabaseConnection
        + findById(): Reservation
        + findByGuest(): List<Reservation>
        + save(): Reservation
        + update(): void
    }
}

' ============================================================
' DESIGN PATTERNS
' ============================================================

package "Design Patterns" {
    package "Strategy Pattern (Pricing)" {
        interface "IPricingStrategy" {
            + calculateTotal(): double
        }

        class "StandardRateStrategy" implements IPricingStrategy {
            + calculateTotal(): double
        }

        class "SeasonalRateStrategy" implements IPricingStrategy {
            - multiplier: double
            + calculateTotal(): double
            + setMultiplier(): void
        }
    }

    package "Adapter Pattern (Payment)" {
        interface "IPaymentAdapter" {
            + pay(): boolean
        }

        class "POSAdapter" implements IPaymentAdapter {
            - posSystem: ExternalPOSSystem
            + pay(): boolean
        }

        class "OnlineGatewayAdapter" implements IPaymentAdapter {
            - bankPortal: SecureBankPortal
            + pay(): boolean
        }
    }

    package "Singleton Pattern (Database)" {
        class "DatabaseConnection <<Singleton>>" {
            - {static} instance: DatabaseConnection
            - dataSource: HikariDataSource
            + {static} getInstance(): DatabaseConnection
            + getConnection(): Connection
            + close(): void
        }
    }
}

' ============================================================
' ENTITIES
' ============================================================

package "Entity Layer (Domain Model)" {
    class "User" {
        +id: int
        +username: String
        +passwordHash: String
        +role: String
        +validatePassword(): boolean
    }

    class "Guest" {
        +id: int
        +name: String
        +nic: String
        +phone: String
        +updateContact(): void
    }

    class "Room" {
        +id: int
        +number: String
        +type: String
        +price: double
        +status: String
        +markClean(): void
        +updateStatus(): void
    }

    class "Reservation (abstract)" {
        +id: String
        +guestId: int
        +roomId: int
        +totalAmount: double
        +status: String
        + {abstract} getReservationType(): String
        +confirm(): void
        +checkIn(): void
        +checkOut(): void
    }

    class "OnlineReservation" extends Reservation {
        +emailSent: boolean
        +markEmailSent(): void
        +getReservationType(): String
    }

    class "WalkInReservation" extends Reservation {
        +receiptPrinted: boolean
        +markReceiptPrinted(): void
        +getReservationType(): String
    }
}

' ============================================================
' PERSISTENCE LAYER
' ============================================================

package "Persistence Layer" <<BGCOLOR_DB>> {
    class "Database" {
        +users
        +guests
        +rooms
        +reservations
        +maintenance_tasks
        +payment_transactions
    }
}

' ============================================================
' RELATIONSHIPS
' ============================================================

' Web Layer → Controller Layer
LoginServlet --> SystemController : "delegates"
ReservationServlet --> ReservationController : "delegates"
FrontDeskServlet --> FrontDeskController : "delegates"
AdminServlet --> AdminController : "delegates"
AuthFilter --> SystemController : "validates with"

' Controllers → Services
SystemController --> UserService : "uses"
ReservationController --> BookingService : "uses"
FrontDeskController --> BookingService : "uses"
AdminController --> UserService : "uses"
AdminController --> ReportService : "uses"

' Controllers → Mappers
ReservationController --> "GuestMapper\nRoomMapper" : "uses"

' Services → Services (Facade coordination)
BookingService --> OnlineResService : "coordinates"
BookingService --> WalkInResService : "coordinates"
BookingService --> RoomService : "coordinates"
BookingService --> PaymentService : "coordinates"

' Services → Repositories
UserService --> UserRepository : "uses"
RoomService --> RoomRepository : "uses"
ReservationService --> ReservationRepository : "uses"
PaymentService --> ReservationRepository : "uses"

' Services → Strategies/Adapters
ReservationService --> IPricingStrategy : "uses"
PaymentService --> IPaymentAdapter : "uses"

' Repositories → DAO Implementations
UserRepository <|-- UserDAOImpl : "implements"
RoomRepository <|-- RoomDAOImpl : "implements"
ReservationRepository <|-- ReservationDAOImpl : "implements"

' DAOs → Database Connection
UserDAOImpl --> DatabaseConnection : "uses"
RoomDAOImpl --> DatabaseConnection : "uses"
ReservationDAOImpl --> DatabaseConnection : "uses"

' Database Connection → Database
DatabaseConnection --> Database : "connects to"

' Entities
UserService --> User : "manages"
UserService --> UserDTO : "returns"
RoomService --> Room : "manages"
RoomService --> RoomDTO : "returns"
ReservationService --> Reservation : "creates"
ReservationService --> ReservationDTO : "returns"

' Mappers
UserMapper --> User : "converts to/from"
UserMapper --> UserDTO : "converts to/from"
GuestMapper --> Guest : "converts to/from"
GuestMapper --> GuestDTO : "converts to/from"
RoomMapper --> Room : "converts to/from"
RoomMapper --> RoomDTO : "converts to/from"

' JSP Views
LoginServlet --> "login.jsp" : "renders"
ReservationServlet --> "roomSearch.jsp\nsearchResults.jsp\nreservation.jsp\nreservationConfirmation.jsp\nmyReservations.jsp\ncancelReservation.jsp\ncancelConfirmation.jsp" : "renders"
FrontDeskServlet --> "receptionistDashboard.jsp\nwalkInForm.jsp\nwalkInConfirmation.jsp\ncheckIn.jsp\ncheckInConfirmation.jsp\ncheckOut.jsp\nbill.jsp" : "renders"
AdminServlet --> "adminDashboard.jsp\nstaffManagement.jsp\nstaffCreationConfirmation.jsp\nreports.jsp\nrevenueReport.jsp\noccupancyReport.jsp\ncomprehensiveReport.jsp\ncancellationReport.jsp\npaymentConfig.jsp\npaymentConfigConfirmation.jsp\nmaintenance.jsp\nmaintenanceConfirmation.jsp" : "renders"

@enduml

